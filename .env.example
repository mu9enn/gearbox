# No secrets are required by the current codebase.
# Current scripts mostly use hard-coded relative paths and set PYTHONHASHSEED internally.

# Optional reproducibility setting if you run scripts from a shell.
PYTHONHASHSEED=42

# Optional path variables for future refactors; current scripts do not read these yet.
PROJECT_ROOT=/path/to/GearBox
DATA_ROOT=/path/to/GearBox/DataSets

